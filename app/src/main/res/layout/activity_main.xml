<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_screen">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_margin="16dp"
        android:background="@drawable/bg_input"
        android:orientation="horizontal"
        android:padding="4dp">

        <TextView
            android:id="@+id/tabMembers"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_tab_selected"
            android:gravity="center"
            android:text="Members"
            android:textColor="@color/white"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tabExpenses"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_tab_unselected"
            android:gravity="center"
            android:text="Expenses"
            android:textColor="@color/text_dark"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tabSettlement"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_tab_unselected"
            android:gravity="center"
            android:text="Settlement"
            android:textColor="@color/text_dark"
            android:textStyle="bold" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnOpenNotes"
        style="@style/Widget.MaterialComponents.Button.TextButton.Icon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Notes"
        android:textColor="@color/purple_primary"
        app:iconTint="@color/purple_primary"
        android:layout_gravity="end"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp"/>

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingBottom="40dp">

            <LinearLayout
                android:id="@+id/layoutMembers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Add to Trip"
                    android:textColor="@color/text_dark"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"
                    android:layout_marginStart="4dp"/>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp"
                    android:layout_marginBottom="24dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <EditText
                            android:id="@+id/etMemberName"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:background="@drawable/bg_input"
                            android:hint="Enter member name"
                            android:paddingHorizontal="16dp"
                            android:textColor="@color/text_dark"
                            android:layout_marginBottom="16dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnAddMember"
                            android:layout_width="match_parent"
                            android:layout_height="55dp"
                            android:text="+ Add Member"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            app:backgroundTint="@color/purple_primary"
                            app:cornerRadius="12dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Current Travelers"
                            android:textColor="@color/text_dark"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="12dp" />

                        <TextView
                            android:id="@+id/tvMemberList"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="No members yet."
                            android:textColor="@color/purple_primary"
                            android:fontFamily="sans-serif-monospace" 
                            android:textStyle="bold"
                            android:textSize="16sp"
                            android:lineSpacingExtra="6dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutExpenses"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Log New Expense"
                    android:textColor="@color/text_dark"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"
                    android:layout_marginStart="4dp"/>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp"
                    android:layout_marginBottom="24dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <Spinner
                            android:id="@+id/spinnerPayer"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:background="@drawable/bg_input"
                            android:layout_marginBottom="12dp"/>

                        <Spinner
                            android:id="@+id/spinnerCategory"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:background="@drawable/bg_input"
                            android:layout_marginBottom="12dp"/>

                        <EditText
                            android:id="@+id/etTitle"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:background="@drawable/bg_input"
                            android:hint="Add Expense Name"
                            android:paddingHorizontal="16dp"
                            android:layout_marginBottom="12dp" />

                        <EditText
                            android:id="@+id/etAmount"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:background="@drawable/bg_input"
                            android:hint="Amount (₹)"
                            android:inputType="numberDecimal"
                            android:paddingHorizontal="16dp"
                            android:layout_marginBottom="16dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Split Between:"
                            android:textColor="@color/text_dark"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp"/>

                        <LinearLayout
                            android:id="@+id/llInvolvedMembers"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginBottom="16dp"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnAddExpense"
                            android:layout_width="match_parent"
                            android:layout_height="55dp"
                            android:text="Save Expense"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            app:backgroundTint="@color/purple_primary"
                            app:cornerRadius="12dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingTop="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Expense History"
                            android:textColor="@color/text_dark"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_marginStart="16dp"
                            android:layout_marginBottom="8dp" />

                        <com.example.tripexpense.NonScrollListView
                            android:id="@+id/lvExpenses"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content" 
                            android:divider="@color/divider_color"
                            android:dividerHeight="1dp"
                            android:paddingHorizontal="16dp"
                            android:paddingBottom="16dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutSettlement"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Final Balances"
                    android:textColor="@color/text_dark"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"
                    android:layout_marginStart="4dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCalculate"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:text="Calculate Splits"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:backgroundTint="@color/purple_primary"
                    app:cornerRadius="16dp"
                    app:elevation="2dp"
                    android:layout_marginBottom="12dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSettleUp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:text="Log a Payment (Settle Up)"
                    android:textColor="@color/purple_primary"
                    app:strokeColor="@color/purple_primary"
                    app:strokeWidth="2dp"
                    app:cornerRadius="16dp"
                    android:layout_marginBottom="24dp"/>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="How to Settle Up"
                            android:textColor="@color/purple_dark"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="12dp"/>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/divider_color"
                            android:layout_marginBottom="16dp"/>

                        <TextView
                            android:id="@+id/tvResults"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Press calculate to see who owes whom."
                            android:textColor="@color/text_dark"
                            android:textSize="16sp"
                            android:fontFamily="sans-serif-monospace"
                            android:lineSpacingExtra="10dp"/> 

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Individual Summary"
                            android:textColor="@color/purple_dark"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="12dp"/>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/divider_color"
                            android:layout_marginBottom="16dp"/>

                        <TableLayout
                            android:id="@+id/tableSummary"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:stretchColumns="*"> 
                            
                            <TableRow android:paddingBottom="12dp">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Name"
                                    android:textColor="@color/text_gray"
                                    android:textStyle="bold"
                                    android:textSize="12sp"/>
                                
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Paid"
                                    android:gravity="center"
                                    android:textColor="@color/text_gray"
                                    android:textStyle="bold"
                                    android:textSize="12sp"/>
                                
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Share"
                                    android:gravity="center"
                                    android:textColor="@color/text_gray"
                                    android:textStyle="bold"
                                    android:textSize="12sp"/>
                                
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Balance"
                                    android:gravity="end"
                                    android:textColor="@color/text_gray"
                                    android:textStyle="bold"
                                    android:textSize="12sp"/>
                            </TableRow>

                        </TableLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSeeIndividualExpenses"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="16dp"
                    android:text="See Individual Expenses"
                    android:textColor="@color/purple_primary"
                    app:strokeColor="@color/purple_primary"
                    app:strokeWidth="2dp"
                    app:cornerRadius="16dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnShareReport"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="16dp"
                    android:text="Share to WhatsApp"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    app:backgroundTint="#25D366" 
                    app:cornerRadius="16dp" />

                
            </LinearLayout>

        </FrameLayout>
    </ScrollView>
</LinearLayout>
